## Fase 2 — App Móvil (Config con la Sesión)

### 2.1 [CREATE] `mobile/app/contexts/OrderConfigContext.tsx`

Nuevo contexto simple (sin React Query) que gestiona la config de statuses:

```typescript
import React, { createContext, useContext, useState, useEffect, ReactNode } from 'react';
import AsyncStorage from '@react-native-async-storage/async-storage';
import orderConfigService from '@/services/api/orderConfig';
import {
  ORDER_STATUS_LABELS,
  ORDER_STATUS_COLORS,
  ORDER_STATUS_ICONS,
} from '@/constants/orderStates';

const CONFIG_KEY = '@enlared/order_config';

export interface MobileStatusConfig {
  label: string;
  color: string;
  icon: string;
  isTerminal: boolean;
  countsAsCompleted: boolean;
}

interface OrderConfigContextType {
  statuses: Record<string, MobileStatusConfig>;
  completedStatuses: string[];
  terminalStatuses: string[];
  validStatuses: string[];
  getStatusConfig: (status: string) => MobileStatusConfig;
  isLoaded: boolean;
}

const OrderConfigContext = createContext<OrderConfigContextType | undefined>(undefined);

export function OrderConfigProvider({ children }: { children: ReactNode }) {
  const [statuses, setStatuses] = useState<Record<string, MobileStatusConfig>>(buildFallback());
  const [completedStatuses, setCompletedStatuses] = useState<string[]>(['completed', 'completed_special']);
  const [terminalStatuses, setTerminalStatuses] = useState<string[]>([]);
  const [validStatuses, setValidStatuses] = useState<string[]>([]);
  const [isLoaded, setIsLoaded] = useState(false);

  // Al montar: cargar desde AsyncStorage (instantáneo, sin red)
  useEffect(() => {
    loadFromStorage();
  }, []);

  async function loadFromStorage() {
    try {
      const stored = await AsyncStorage.getItem(CONFIG_KEY);
      if (stored) {
        const data = JSON.parse(stored);
        applyConfig(data);
      }
    } catch (e) {
      console.warn('Error loading config from storage:', e);
    }
    setIsLoaded(true);
  }

  // Llamado por AuthContext después del login exitoso
  async function fetchAndStoreConfig() {
    try {
      const data = await orderConfigService.getOrderConfig();
      await AsyncStorage.setItem(CONFIG_KEY, JSON.stringify(data));
      applyConfig(data);
    } catch (e) {
      console.warn('Error fetching order config:', e);
      // No crash — ya tenemos fallback o AsyncStorage previo
    }
  }

  function applyConfig(data: any) {
    if (data.statuses) {
      const mobile: Record<string, MobileStatusConfig> = {};
      for (const [key, cfg] of Object.entries(data.statuses) as any) {
        mobile[key] = {
          label: cfg.label,
          color: mapColorToHex(cfg.color, key),
          icon: cfg.icon,
          isTerminal: cfg.isTerminal,
          countsAsCompleted: cfg.countsAsCompleted,
        };
      }
      setStatuses(mobile);
    }
    if (data.completedStatuses) setCompletedStatuses(data.completedStatuses);
    if (data.terminalStatuses) setTerminalStatuses(data.terminalStatuses);
    if (data.validStatuses) setValidStatuses(data.validStatuses);
  }

  function getStatusConfig(status: string): MobileStatusConfig {
    return statuses[status] || { label: status || 'Desconocido', color: '#9e9e9e', icon: 'help-circle', isTerminal: false, countsAsCompleted: false };
  }

  const value = { statuses, completedStatuses, terminalStatuses, validStatuses, getStatusConfig, isLoaded, fetchAndStoreConfig };
  return <OrderConfigContext.Provider value={value}>{children}</OrderConfigContext.Provider>;
}

export function useOrderConfig() {
  const ctx = useContext(OrderConfigContext);
  if (!ctx) throw new Error('useOrderConfig must be inside OrderConfigProvider');
  return ctx;
}
```

